{
  "name": "corus",
  "private": true,
  "version": "0.1.2",
  "description": "CORUS - Gestor de Corais Apostolicos",
  "author": "jonatassgoncalvess-art",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "desktop": "electron .",
    "dist:win": "npm run build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-quill-new": "^3.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.3",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "br.com.corus.desktop",
    "productName": "CORUS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/corus-logo.png",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
